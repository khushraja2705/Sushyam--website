// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: products
// Fields:
//   - name: string (required)
//   - tags: string (required)
//   - image: string (required)
//   - badge: string (optional)
//   - prices: map (required) { 3ml: number, 5ml: number }
//
// Collection: orders
// Fields:
//   - userUid: string (required) - The UID of the user who placed the order
//   - userEmail: string (required)
//   - items: list (required) - List of { productId, size, quantity }
//   - total: number (required)
//   - status: string (required) - ['pending', 'completed', 'cancelled']
//   - createdAt: timestamp (required)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "khushraja5@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'tags', 'image', 'prices']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.tags is string && data.tags.size() < 200 &&
             data.image is string && data.image.matches("^https://.*") &&
             data.prices is map &&
             data.prices.get('3ml', 0) is number &&
             data.prices.get('5ml', 0) is number;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userUid', 'userEmail', 'items', 'total', 'status', 'createdAt']) &&
             data.userUid == request.auth.uid &&
             data.userEmail is string &&
             data.items is list && data.items.size() > 0 && data.items.size() < 50 &&
             data.total is number && data.total >= 0 &&
             data.status in ['pending', 'completed', 'cancelled'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin() && isValidProduct(request.resource.data);
    }

    match /orders/{orderId} {
      allow create: if isAuthenticated() && isValidOrder(request.resource.data);
      allow read: if isOwner(resource.data.userUid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
